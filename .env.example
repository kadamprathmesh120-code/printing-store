# =============================================================================
# Razorpay API credentials
# =============================================================================
# This file is a template. Copy it to .env (which is gitignored) and fill in
# your keys for local development. On Render, set these same variable names
# in Render Dashboard → Your Service → Environment Variables instead.
#
# Switching between Test and Live mode (no code changes needed):
# ------------------------------------------------------------------------
#   Test mode: Get test keys from https://dashboard.razorpay.com/app/test
#              Test keys start with "rzp_test_..."
#   Live mode: Get live keys from https://dashboard.razorpay.com/app/keys
#              Live keys start with "rzp_live_..."
#
# Simply change the values below (or in Render Dashboard) — the application
# reads whatever is set in the environment.
#
# WARNING: Never commit real keys to Git. The .env file is in .gitignore.
#          For production, use Render's Environment Variables feature.
# =============================================================================

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
